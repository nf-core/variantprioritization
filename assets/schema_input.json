{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://raw.githubusercontent.com/nf-core/variantprioritization/master/assets/schema_input.json",
    "title": "nf-core/variantprioritization pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "patient": {
                "pattern": "^\\S+$",
                "meta": ["patient"]
            },
            "status": {
                "type": "integer",
                "enum": [0, 1],
                "errorMessage": "Status parameter must be either '0' (Normal) or '1' (Tumor)",
                "meta": ["status"]
            },
            "sample": {
                "type": "string",
                "pattern": "^\\S+$",
                "errorMessage": "Sample name must be provided and cannot contain spaces",
                "meta": ["sample"]
            },
            "vcf": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.vcf(\\.gz)?$",
                "errorMessage": "VCF file must be provided, cannot contain spaces and must have extension '.vcf' or '.vcf.gz'"
            },
            "cna": {
                "type": "string",
                "format": "file-path",
                "exists": true,
                "pattern": "^\\S+\\.(cns|txt)$",
                "errorMessage": "CNA file cannot contain spaces and must have extension '.cns'"
            }
        },
        "required": ["patient", "status", "sample", "vcf"]
    }
}
