nextflow_workflow {

    name "Test Subworkflow PREPARE_SOMATIC"
    script "../main.nf"
    workflow "PREPARE_SOMATIC"

    tag "subworkflows"
    tag "subworkflows_"
    tag "subworkflows/prepare_somatic"
    tag "pcgr/getref"
    tag "ci_test"

    test("20250314 - 113") {

        when {
            workflow {
                """
                input[0] = 'GRCh38'
                input[1] = false
                input[2] = '20250314'
                input[3] = 'https://github.com/nf-core/test-datasets/raw/refs/heads/variantprioritization/reference/pcgr_ref_grch38_chr22.tar.gz'
                input[4] = 'https://github.com/nf-core/test-datasets/raw/refs/heads/variantprioritization/reference/vep_cache_113_GRCh38_chr22.tar.gz'
                input[5] = '113'
                input[6] = 'homo_sapiens'
                """
            }
        }
        then {
            assert workflow.success
            assertAll(
                { assert snapshot(sanitizeOutput(workflow.out)).match() }
            )
        }
    }
}
