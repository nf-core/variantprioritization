nextflow_process {

    name "Test Process INTERSECT_VCF"
    script "../main.nf"
    process "INTERSECT_VCF"

    tag "modules"
    tag "intersect/vcf"
    tag "ci_test"

    test("human - vcf.gz") {

        when {
            process {
                """
                input[0] = [
                    [id:'HCC1395.HCC1395T', patient:'HCC1395', sample:'HCC1395T'],
                    [
                        file(params.pipelines_testdata_base_path + "module_data/preparevcf/HCC1395.HCC1395T.mutect2.reformatted.vcf.gz", checkIfExists: true),
                        file(params.pipelines_testdata_base_path + "module_data/preparevcf/HCC1395.HCC1395T.strelka_indel.reformatted.vcf.gz", checkIfExists: true),
                        file(params.pipelines_testdata_base_path + "module_data/preparevcf/HCC1395.HCC1395T.strelka_snv.reformatted.vcf.gz", checkIfExists: true)
                    ],
                    [
                        file(params.pipelines_testdata_base_path + "module_data/preparevcf/HCC1395.HCC1395T.mutect2.reformatted.vcf.gz.tbi", checkIfExists: true),
                        file(params.pipelines_testdata_base_path + "module_data/preparevcf/HCC1395.HCC1395T.strelka_indel.reformatted.vcf.gz.tbi", checkIfExists: true),
                        file(params.pipelines_testdata_base_path + "module_data/preparevcf/HCC1395.HCC1395T.strelka_snv.reformatted.vcf.gz.tbi", checkIfExists: true)
                    ]
                ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out)).match() },
            )
        }

    }

}
