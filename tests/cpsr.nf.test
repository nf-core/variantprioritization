nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"
    tag "ci_test"

    def test_scenario = [
        [
            name: "-profile test",
            params: [
                input: "tests/cpsr-sheet.csv",
                analysis: 'germline',
            ]
        ]
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.get_test(scenario))
    }
}
