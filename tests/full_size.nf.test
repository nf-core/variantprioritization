nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    def test_scenario = [
        [
            name: "-profile test_full",
            params: []
        ]
    ]

    // Generate tests for each scenario
    test_scenario.each { scenario ->
        test(scenario.name, UTILS.get_test(scenario))
    }
}
