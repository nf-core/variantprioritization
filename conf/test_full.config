/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running full-size tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a full size pipeline test.

    Use as follows:
        nextflow run nf-core/variantprioritization -profile test_full,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Full test dataset to check pipeline function'

    // Input data for full size test
    input                      = params.pipelines_testdata_base_path + 'variantprioritization/samplesheets/test_full.csv'

    // Other settings
    pcgr_download              = true
    pcgr_bundleversion         = 20250314
    vep_cache                  = 's3://annotation-cache/vep_cache/'
    vep_cache_version          = 113
    vep_species                = 'homo_sapiens'
    genome                     = 'GRCh38'
    assay                      = 'WES'
    estimate_signatures        = true
    estimate_msi               = true
    estimate_tmb               = true
    cna_analysis               = true
    vcf2maf                    = true
    filter_mutect2             = "-i 'FILTER=\"PASS\"'"
    filter_strelka_indels      = "-i 'FILTER=\"PASS\"'"
    filter_strelka_snvs        = "-i 'FILTER=\"PASS\"'"
}
