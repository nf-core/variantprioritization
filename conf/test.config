/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/nfpgcrdev -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // PCGR params
    input  = 'https://raw.githubusercontent.com/BarryDigby/nf-core-pcgr/dev/assets/test_data/samplesheet.csv'
    database = null // user must point to this
    genome = 'GRCh38'
    mode   = 'pcgr'
    fasta = 'https://raw.githubusercontent.com/BarryDigby/nf-core-pcgr/dev/assets/test_data/GRCh38_chr1_15MBP.fasta'
    assay = 'WES'
    estimate_signatures = true
    estimate_msi_status = true
    estimate_tmb = true
    cna_analysis = true
}
